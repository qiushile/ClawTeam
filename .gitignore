*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
.cache/
.tmp/

# 图片文件
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.webp

# 构建产物
dist/
build/
*.pyc
__pycache__/
node_modules/
/pnpm-lock.yaml
**/package-lock.json

# Docker 相关
.docker/
*.dockerfile.local

# 本地配置覆盖
*.local.json
*.local.yaml
*.local.yml

# 数据库文件
*.db
*.sqlite
*.sqlite3

# OpenClaw 运行时文件
**/.openclaw/*
*/agents/
*/canvas/
*/credentials/
*/cron/
*/feishu/
*.bak
*.bak.*
update-check.json
health-state.json
/monitor/daily-report-*.md
/monitor/daily-report-state.json
*/update-check.json
*/health-state.json
*/woekspace-state.json

# 哨兵整合 - 运行时生成
openclaw-*/workspace/.openclaw/
openclaw-*/identity/
openclaw-*/subagents/
workspace-*/

# Skills - ClawHub 安装信息
sentinel/workspace/skills/*/.clawhub/

# ClawSec - 动态安全情报 feed
sentinel/workspace/skills/clawsec-suite/advisories/feed.json

# Moltguard - SQLite 运行时文件
sentinel/extensions/moltguard/data/*.db-shm
sentinel/extensions/moltguard/data/*.db-wal

# 每日报告
*daily_*.md
*report_*.md

# 备份文件
backups/

# 设备配对凭证（敏感）
openclaw-*/devices/

# 测试脚本（可能包含敏感信息）
test-db*.js
*/test_db.js
*-test.js
test_*.js
*.test.js

# 运行时数据
openclaw-*/delivery-queue/
openclaw-*/workspace/memory/
*-summary.md
*daily_*.md
*report_*.md

# 缓存
.clawhub/
**/.clawhub/

# 开发测试目录
openclaw-dev/dbtest/

# Workspace 中的敏感配置文件
**/workspace/*-config.json
**/workspace/memory-*.json
**/workspace/.env
**/workspace/credentials/
**/workspace/*.key
**/workspace/*.pem

# Workspace 测试和临时文件
**/workspace/test-*.js
**/workspace/*-test.js
**/workspace/*.test.js

# 远端工作树运行时状态
/monitor/*-state.json

# Agent 运行时记忆与日报产物
openclaw-*/memory/
openclaw-*/workspace/daily_reports/

# QA 下载的 GitHub CLI 安装包
openclaw-qa/workspace/gh_*.tar.gz
openclaw-qa/workspace/gh_*/

# Moltguard 损坏数据库备份
sentinel/extensions/moltguard/data/*.db.corrupted.*

# 额外备份后缀
*.bak[0-9]*
