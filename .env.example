# 这里用的是阿里云百炼 API Key (用于调用 Qwen/GLM/DeepSeek 等)
ALIYUN_API_KEY=sk-你的真实阿里云密钥

# OpenClaw 内网通信鉴权 Token (自 v2026.3.7 起强制要求) [1, 2]
SECRET_GATEWAY_TOKEN=my_super_secret_token_2026

# PostgreSQL 数据库凭证与 Schema密码配置
POSTGRES_PASSWORD=root_super_password
ORCHESTRATOR_DB_PASS=orchestrator_pass_123
DEV_DB_PASS=dev_pass_123
PM_DB_PASS=pm_pass_123
DESIGN_DB_PASS=design_pass_123
ADS_DB_PASS=ads_pass_123
SALES_DB_PASS=sales_pass_123
MARKETING_DB_PASS=marketing_pass_123
PROJECT_DB_PASS=project_pass_123
QA_DB_PASS=qa_pass_123
SUPPORT_DB_PASS=support_pass_123
SPATIAL_DB_PASS=spatial_pass_123
EXPERT_DB_PASS=expert_pass_123
GAME_DB_PASS=game_pass_123

