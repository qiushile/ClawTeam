# Hermes Agent 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# === 模型 Provider ===
# 阿里云百炼 (DashScope / Coding Plan)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (可选)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (可选)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 飞书 (Feishu/Lark) ===
# 秘书处应用
FEISHU_SECRETARIAT_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_SECRETARIAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Gateway ===
GATEWAY_TOKEN=your-gateway-token-here

# === 其他可选配置 ===
# ElevenLabs TTS
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenHue (智能家居)
OPENHUE_CLIENT_ID=xxxxxxxxxxxxxxxx
OPENHUE_CLIENT_SECRET=xxxxxxxxxxxxxxxx
