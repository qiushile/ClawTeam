{
  "gateway": {
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "my_super_secret_token_2026"
    }
  },
  "models": {
    "primary": {
      "provider": "openai-compatible",
      "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "apiKey": "${DASHSCOPE_API_KEY}",
      "model": "qwen2.5-72b-instruct" 
    },
    "fallback": {
      "provider": "openai-compatible",
      "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "apiKey": "${DASHSCOPE_API_KEY}",
      "model": "qwen-plus"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "primary",
        "fallbacks": ["fallback"]
      },
      "costControl": {
        "enabled": true,
        "limits": { "daily": 10.0 }
      },
      "tools": {
        "deny": ["exec", "bash", "process", "file_delete"] 
      }
    }
  }
}